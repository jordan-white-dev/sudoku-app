{
  "name": "sudoku-app",
  "version": "1.0.0",
  "private": true,
  "author": "jordanwhite",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "type:check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --passWithNoTests",
    "test:browser": "vitest --browser=chromium",
    "test:coverage": "vitest --coverage run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "check": "pnpm biome:check && pnpm type:check && pnpm test && pnpm build && pnpm knip",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-timer-hook": "^4.0.5",
    "sudoku": "^0.0.3",
    "super-expressive": "^2.0.0",
    "use-session-storage-state": "^19.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.10",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "knip": "^6.1.0",
    "playwright": "^1.58.2",
    "typescript": "6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0"
  }
}
